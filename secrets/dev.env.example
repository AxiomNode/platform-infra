# platform-infra (dev)
# Copy to secrets/dev.env locally and fill with real values before sealing.
QUIZZ_DB_USER=quiz
QUIZZ_DB_PASSWORD=change-me-dev-quiz-password
QUIZZ_DB_NAME=quizdb
WORDPASS_DB_USER=wordpass
WORDPASS_DB_PASSWORD=change-me-dev-wordpass-password
WORDPASS_DB_NAME=wordpassdb
USERS_DB_USER=users
USERS_DB_PASSWORD=change-me-dev-users-password
USERS_DB_NAME=usersdb
# Optional: path to Firebase service account JSON for users service
FIREBASE_CREDENTIALS_FILE=
DOCKER_REGISTRY=ghcr.io/axiomnode
DOCKER_IMAGE_TAG=dev-latest
COMPOSE_PROJECT_NAME=axiomnode-dev