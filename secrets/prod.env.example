# platform-infra (prod)
# Copy to secrets/prod.env locally and fill with real values before sealing.
QUIZZ_DB_USER=quiz
QUIZZ_DB_PASSWORD=change-me-prod-quiz-password
QUIZZ_DB_NAME=quizdb
WORDPASS_DB_USER=wordpass
WORDPASS_DB_PASSWORD=change-me-prod-wordpass-password
WORDPASS_DB_NAME=wordpassdb
USERS_DB_USER=users
USERS_DB_PASSWORD=change-me-prod-users-password
USERS_DB_NAME=usersdb
# Optional: path to Firebase service account JSON for users service
FIREBASE_CREDENTIALS_FILE=
# Required in prod for external managed databases
QUIZZ_DB_HOST=quizz-db.prod.axiomnode.internal
QUIZZ_DB_PORT=5432
WORDPASS_DB_HOST=wordpass-db.prod.axiomnode.internal
WORDPASS_DB_PORT=5432
USERS_DB_HOST=users-db.prod.axiomnode.internal
USERS_DB_PORT=5432
DOCKER_REGISTRY=ghcr.io/axiomnode
DOCKER_IMAGE_TAG=pro-latest
COMPOSE_PROJECT_NAME=axiomnode-pro